GEMINI_API_KEY=your-gemini-api-key-here

# Multi-user OAuth (required for /login flow)
GOOGLE_CLIENT_ID=your-web-client-id
GOOGLE_CLIENT_SECRET=your-web-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/layla

# Token encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
TOKEN_ENCRYPTION_KEY=your-fernet-key-here
